# Server environment — copy to .env and fill in
NODE_ENV=development
PORT=8080

# MongoDB Atlas connection string (the database "digitalinnovation" is used by default)
MONGO_URI=mongodb+srv://brayw433:Manish333@cluster0.gmw98.mongodb.net/digitalinnovation

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Default admin account (created by the seed script)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Where gallery uploads are stored
UPLOAD_DIR=uploads

# Allowed client origin for CORS
CLIENT_ORIGIN=http://localhost:5173
